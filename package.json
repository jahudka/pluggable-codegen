{
  "name": "pluggable-codegen",
  "version": "0.3.1",
  "license": "MIT",
  "homepage": "https://github.com/jahudka/pluggable-codegen",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jahudka/pluggable-codegen.git"
  },
  "bugs": {
    "url": "https://github.com/jahudka/pluggable-codegen/issues"
  },
  "maintainers": [
    {
      "name": "Dan Kadera",
      "email": "me@subsonic.cz",
      "url": "https://github.com/jahudka"
    }
  ],
  "files": [
    "dist"
  ],
  "bin": {
    "pluggable-codegen": "dist/cli.mjs"
  },
  "type": "module",
  "types": "./dist/index.d.ts",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.js"
    },
    "./presets/*": {
      "types": "./dist/presets/*.d.ts",
      "require": "./dist/presets/*.cjs",
      "import": "./dist/presets/*.js"
    }
  },
  "packageManager": "pnpm@10.30.1",
  "dependencies": {
    "picomatch": "^4.0.4",
    "tinyglobby": "^0.2.16"
  },
  "peerDependencies": {
    "@graphql-codegen/cli": "^5.0.0 || ^6.0.0 || ^7.0.0",
    "yaml": "^2.9.0"
  },
  "peerDependenciesMeta": {
    "@graphql-codegen/cli": {
      "optional": true
    },
    "yaml": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^10.0.1",
    "@graphql-codegen/cli": "^7.0.0",
    "@types/node": "^22.19.19",
    "@types/picomatch": "^4.0.3",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "yaml": "^2.9.0"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "eslint": "eslint .",
    "eslint:fix": "eslint --fix .",
    "prettier": "prettier --check .",
    "prettier:fix": "prettier --write .",
    "lint": "pnpm run '/^(eslint|prettier)$/'",
    "format": "pnpm run --sequential '/^(eslint|prettier):fix$/'",
    "build": "tsc && tsdown"
  }
}
